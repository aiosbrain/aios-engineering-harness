#!/usr/bin/env bash
#
# pre-commit-primary-guard — block feature commits in the PRIMARY checkout.
#
# The portable, repo-neutral commit-time backstop for the worktree convention.
# It is the durable pair to the agent-hook `hooks/guard-worktree.sh`: the agent
# hook intercepts edits and branch-creation inside supported runtimes, while this
# git hook catches every commit path (manual commits, runtimes without hooks,
# scripts) regardless of which agent — if any — is driving.
#
# A commit is BLOCKED when:
#   (a) the working copy is the PRIMARY checkout (not a linked worktree), AND
#   (b) the current branch is NOT the default branch.
#
# It is a NO-OP inside a linked worktree (where feature work belongs) and on the
# default branch in the primary (the rare intentional hotfix).
#
# Config / override:
#   HARNESS_DEFAULT_BRANCH        default branch name (default: main)
#   HARNESS_ALLOW_PRIMARY_COMMIT  set to 1 for a genuine primary-checkout commit
#   AIOS_ALLOW_PRIMARY_COMMIT     honored too, for parity with aios-workspace #388
#
# Installed to `.git/hooks/pre-commit` by `install-primary-commit-guard.sh`, which
# chains any pre-existing pre-commit hook to `.git/hooks/pre-commit.chained`.
# git hooks are not version-controlled; this tracked source is the durable copy.
set -euo pipefail

DEFAULT_BRANCH="${HARNESS_DEFAULT_BRANCH:-main}"

# Resolve both to PHYSICAL paths (pwd -P) so a /var↔/private-style symlink can't
# make the primary checkout look like a linked worktree (git reports the git dir
# physically but a plain `pwd` is logical).
git_dir="$(git rev-parse --absolute-git-dir 2>/dev/null || true)"
if [[ -n "$git_dir" ]]; then
  git_dir="$(cd "$git_dir" 2>/dev/null && pwd -P || echo "$git_dir")"
fi
common_dir="$(git rev-parse --git-common-dir 2>/dev/null || true)"
if [[ -n "$common_dir" ]]; then
  common_dir="$(cd "$common_dir" 2>/dev/null && pwd -P || echo "$common_dir")"
fi

is_primary=0
if [[ -n "$git_dir" && "$git_dir" == "$common_dir" ]]; then
  is_primary=1
fi

if [[ "$is_primary" == "1" ]]; then
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo HEAD)"
  if [[ "$branch" != "$DEFAULT_BRANCH" ]]; then
    if [[ "${HARNESS_ALLOW_PRIMARY_COMMIT:-${AIOS_ALLOW_PRIMARY_COMMIT:-}}" == "1" ]]; then
      echo "[harness] ALLOW_PRIMARY_COMMIT set — allowing commit on '$branch' in the primary checkout." >&2
    else
      repo_root="$(git rev-parse --show-toplevel 2>/dev/null || echo .)"
      cat >&2 <<EOF

┌─────────────────────────────────────────────────────────────────────────────┐
│  harness worktree guard: commit BLOCKED in the PRIMARY checkout              │
└─────────────────────────────────────────────────────────────────────────────┘

You are committing to branch '$branch' inside the PRIMARY checkout:
  $repo_root

Feature work must live in a dedicated git worktree, never on a branch committed
in the primary checkout (it collides with concurrent work and produces duplicate
PRs). Do this instead:

  aios worktree add $branch      # in an AIOS repo
  # or, generically:
  git worktree add -b $branch ../$(basename "$repo_root")-worktrees/${branch//\//-} origin/$DEFAULT_BRANCH
  # then commit there

If this really is an intentional primary-checkout commit (rare hotfix), re-run:

  HARNESS_ALLOW_PRIMARY_COMMIT=1 git commit ...

EOF
      exit 1
    fi
  fi
fi

# Chain to any pre-existing pre-commit hook (e.g. a secrets/leak gate).
chained="$(git rev-parse --git-path hooks/pre-commit.chained 2>/dev/null || true)"
if [[ -n "$chained" && -x "$chained" ]]; then
  exec "$chained" "$@"
fi

exit 0
