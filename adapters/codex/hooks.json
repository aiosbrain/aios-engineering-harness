{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" codex pre_edit guard-secrets.sh",
            "timeout": 30,
            "statusMessage": "Scanning edit for secrets"
          },
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" codex pre_edit guard-protected-paths.sh",
            "timeout": 30,
            "statusMessage": "Checking protected paths"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" codex pre_command guard-destructive.sh",
            "timeout": 30,
            "statusMessage": "Checking destructive command policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" codex post_edit post-edit-format.sh",
            "timeout": 120,
            "statusMessage": "Formatting edited files"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" codex stop stop-verify-gate.sh",
            "timeout": 600,
            "statusMessage": "Running the repository verification gate"
          }
        ]
      }
    ]
  }
}
