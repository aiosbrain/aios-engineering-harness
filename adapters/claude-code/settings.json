{
  "$comment": "Merge into your repo's .claude/settings.json. Assumes the pack is vendored at .harness/ in the repo root (adjust paths if you vendored elsewhere). Skills go to .claude/skills/, agents to .claude/agents/.",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git cherry:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(make test:*)",
      "Bash(make lint:*)",
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" claude-code pre_edit guard-secrets.sh" },
          { "type": "command", "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" claude-code pre_edit guard-protected-paths.sh" },
          { "type": "command", "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" claude-code pre_edit guard-worktree.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" claude-code pre_command guard-destructive.sh" },
          { "type": "command", "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" claude-code pre_command guard-worktree.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" claude-code post_edit post-edit-format.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "\"$(git rev-parse --show-toplevel)/.harness/adapters/run-hook.sh\" claude-code stop stop-verify-gate.sh" }
        ]
      }
    ]
  }
}
